  "keywords": [
    "express",
    "typescript",
    "decorators",
    "routes"
  ],
  "author": "Amechi",
  "license": "MIT",
  "peerDependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.1",
    "express": "^5.2.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^3.2.7"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module"
}
