{
  "name": "modern-express-decorators",
  "version": "1.2.2",
  "description": "A very simple express decorator partly vibecoded and made because I hate long codes a bit",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean && tsc --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "prepare": "npm run build"
